flowchart TB
    classDef src     fill:#f4f4f4,stroke:#555,color:#222
    classDef bronze  fill:#cd7f32,stroke:#7a4c1e,color:#fff
    classDef silver  fill:#c0c0c0,stroke:#555,color:#222
    classDef gold    fill:#ffd700,stroke:#8a7400,color:#222
    classDef cons    fill:#d4edda,stroke:#155724,color:#155724

    SRC["Source<br/>CSV / OLTP feed"]:::src

    subgraph BRONZE["Bronze — Raw Landing<br/>schema: orders_bronze"]
        B1["orders_bronze.bronze_customers"]:::bronze
        B2["orders_bronze.bronze_products"]:::bronze
        B3["orders_bronze.bronze_orders"]:::bronze
        B4["orders_bronze.bronze_order_items"]:::bronze
    end

    subgraph SILVER["Silver — Typed + Clean<br/>schema: orders_silver"]
        S1["orders_silver.silver_customers"]:::silver
        S2["orders_silver.silver_products"]:::silver
        S3["orders_silver.silver_orders"]:::silver
        S4["orders_silver.silver_order_items"]:::silver
    end

    subgraph GOLD["Gold — Business Marts<br/>schema: orders_gold"]
        direction TB
        subgraph DIMFACT["Dims + Atomic Fact"]
            G1["orders_gold.gold_dim_customer"]:::gold
            G2["orders_gold.gold_dim_product"]:::gold
            G3["orders_gold.gold_fact_order_items"]:::gold
            G4["orders_gold.gold_vw_order_status<br/>(derived)"]:::gold
        end
        subgraph AGG["Pre-aggregated Sales Marts"]
            A1["orders_gold.gold_product_daily_sales"]:::gold
            A2["orders_gold.gold_product_weekly_sales"]:::gold
            A3["orders_gold.gold_product_monthly_sales"]:::gold
        end
        G3 --> A1
        G3 --> A2
        G3 --> A3
    end

    subgraph CONSUME["Consumers"]
        C1["BI / Dashboards"]:::cons
        C2["Analyst SQL<br/>(most-sold query)"]:::cons
        C3["ML / Forecasting"]:::cons
    end

    SRC --> BRONZE --> SILVER --> GOLD --> CONSUME
